{
  "name": "survey-frontend",
  "version": "2.0.0",
  "description": "问易答调查系统 前端",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "start:prod": "vite preview --host localhost --port 63000 --strictPort",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "smoke:system": "node ../scripts/system-smoke.mjs",
    "test:build": "vue-tsc --noEmit && vite build",
    "test:smoke": "node ../scripts/system-smoke.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.1.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.4.0",
    "echarts": "^5.4.3",
    "element-plus": "2.3.8",
    "highlight.js": "^11.9.0",
    "pinia": "^2.1.6",
    "qrcode": "^1.5.4",
    "quill": "^1.3.7",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.4.5",
    "@types/qrcode": "^1.5.5",
    "@types/quill": "^2.0.14",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.45.0",
    "eslint-plugin-vue": "^9.15.1",
    "playwright": "^1.58.2",
    "typescript": "~5.1.6",
    "vite": "^4.4.6",
    "vue-tsc": "^1.8.6"
  }
}
