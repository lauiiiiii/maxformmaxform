{
  "name": "survey-backend",
  "version": "2.0.0",
  "description": "问易答调查系统 后端",
  "type": "module",
  "scripts": {
    "start": "node ./scripts/start-prod.js",
    "start:prod": "node ./scripts/start-prod.js",
    "dev": "node --watch ./scripts/start-dev.js",
    "dev:once": "node ./scripts/start-dev.js",
    "test": "node --test --test-concurrency=1",
    "test:watch": "node --watch --test --test-concurrency=1",
    "db:migrate": "node scripts/db-migrate.js",
    "db:seed": "node scripts/db-seed.js",
    "db:seed:dev": "node scripts/db-seed.js",
    "db:seed:init-admin": "node initAdmin.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0"
  }
}
